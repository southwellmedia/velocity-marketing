---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@/components/marketing/Hero.astro';
import CredibilityStrip from '@/components/marketing/CredibilityStrip.astro';
import BentoGrid from '@/components/marketing/BentoGrid';
import Showcase from '@/components/marketing/Showcase';
import TemplatesTeaser from '@/components/marketing/TemplatesTeaser';
import GetStarted from '@/components/marketing/GetStarted.astro';
---

<MarketingLayout
  title="Velocity — Astro 6 Starter Kit & Boilerplate"
  description="The production-ready Astro 6 starter kit and boilerplate. 57+ components, a full design token system, built-in i18n, and perfect Lighthouse scores. Free and open source."
  image="/velocity-og.jpg"
  imageAlt="Velocity — Astro 6 Starter Kit & Boilerplate"
>
  <Hero />
  <CredibilityStrip />
  <BentoGrid client:visible />
  <Showcase client:visible />
  <TemplatesTeaser client:visible />
  <GetStarted />
</MarketingLayout>
